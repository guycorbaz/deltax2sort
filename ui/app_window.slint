import {
    Button,
    VerticalBox,
    HorizontalBox,
    StandardListView,
    LineEdit,
} from "std-widgets.slint";

// One candidate class offered when labelling an unknown object: its name and a
// human-readable similarity (e.g. "72%").
export struct Candidate {
    name: string,
    score: string,
}

export component AppWindow inherits Window {
    title: "Delta X2 Part Sorting System";
    // Target: the official Raspberry Pi 7" Touch Display. The whole
    // operator view (E-stop included) must fit 800x480 with NO scrolling.
    min-width: 800px;
    min-height: 480px;
    preferred-width: 800px;
    preferred-height: 480px;
    background: #121212;

    in property <image> camera-feed: @image-url("");
    // True when no fresh frame has arrived for ~1 s: the feed is shown as
    // LOST rather than silently frozen on the last image.
    in property <bool> feed-lost: false;
    in property <string> robot-status: "Disconnected";
    in property <string> conveyor-status: "Stopped";
    in property <int> bricks-sorted: 0;
    in property <bool> is-running: false;
    // Safety interlock: set from the orchestrator's confirmed state after an
    // E-stop; Start stays disabled until a successful re-home clears it.
    in property <bool> estopped: false;
    // True while a conveyor command is in flight. Debounces the Start/Pause
    // toggle: a double-tap can't spawn a second, racing command.
    in property <bool> command-pending: false;
    // Confirmed orchestrator "actively sorting" state, mirrored from the
    // orchestrator's state watch (robot business, NOT the conveyor). Used to
    // gate Home so it is offered only when homing is meaningful.
    in property <bool> orchestrator-running: false;
    // A Home was requested and has not yet been confirmed complete. Set
    // optimistically on click (like `command-pending` for the belt); cleared
    // when the orchestrator publishes its next confirmed state. Gives the
    // operator immediate feedback and blocks a confusing double-tap.
    in property <bool> home-pending: false;
    // Last hardware error shown to the operator ("" = none). While set, Stop
    // stays available so the belt can be forced down after a failed command.
    in property <string> error-text: "";
    // Manual gripper state (operator toggle). Set optimistically on click;
    // failures surface through error-text.
    in property <bool> gripper-on: false;
    // True in the "workstation" profile: unlocks the learning UI. The Pi/kiosk
    // profile leaves it false (sorting only).
    in property <bool> workstation: false;
    // Learning UI (workstation): shown when an unrecognised object is waiting
    // to be labelled. `learn-crop` is its thumbnail; `learn-candidates` the
    // nearest known classes to offer.
    in property <bool> learning-active: false;
    in property <image> learn-crop;
    in property <[Candidate]> learn-candidates;
    // The operator labelled the pending object: assign it to an existing class,
    // create a new class with this name, or skip it.
    callback learn-assign(string);
    callback learn-create(string);
    callback learn-skip();
    // Export the learned catalogue (workstation) and confirm where it is.
    callback export-catalog();
    in property <string> export-status: "";

    callback start-clicked();
    callback stop-clicked();
    callback home-clicked();
    callback estop-clicked();
    // Operator gripper toggle; argument is the requested new state.
    callback gripper-toggle(bool);

    VerticalBox {
        padding: 10px;
        spacing: 8px;

        // Header (kept shallow so the columns get the vertical space)
        HorizontalBox {
            padding: 0px;
            Text {
                text: "Part Sorting Terminal";
                font-size: 20px;
                color: #ffffff;
                font-weight: 700;
            }

            Rectangle { } // Spacer
            Text {
                text: "Status: " + robot-status;
                color: estopped ? #f44336 : (is-running ? #4caf50 : #ffb74d);
                vertical-alignment: center;
                font-weight: 600;
            }
        }

        HorizontalBox {
            padding: 0px;
            spacing: 10px;

            // Left Column: Live Feed & Analytics
            VerticalBox {
                padding: 0px;
                spacing: 8px;

                // Camera View — flexible: takes whatever height remains.
                Rectangle {
                    background: #1e1e1e;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: #333333;
                    min-height: 160px;
                    vertical-stretch: 1;
                    if (camera-feed.width > 0): Image {
                        source: camera-feed;
                        width: 100%;
                        height: 100%;
                        // Preserve aspect ratio; letterbox inside the panel.
                        image-fit: contain;
                    }
                    if (camera-feed.width == 0 && !feed-lost): Text {
                        text: "Camera Feed Disconnected";
                        color: #555555;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                    }
                    // Staleness banner: overlays the (now stale) last frame so
                    // the operator never mistakes a frozen image for a live one.
                    if (feed-lost): Rectangle {
                        background: #000000cc;
                        Text {
                            text: "⚠  FEED LOST";
                            color: #f44336;
                            font-size: 24px;
                            font-weight: 900;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                    }
                }

                // Stats Box
                Rectangle {
                    background: #1e1e1e;
                    border-radius: 8px;
                    height: 60px;
                    HorizontalBox {
                        padding: 8px;
                        VerticalBox {
                            padding: 0px;
                            Text {
                                text: "Total Sorted";
                                color: #aaaaaa;
                                font-size: 11px;
                            }

                            Text {
                                text: bricks-sorted;
                                color: #ffffff;
                                font-size: 18px;
                                font-weight: 700;
                            }
                        }

                        Rectangle {
                            width: 1px;
                            background: #333333;
                        } // Separator
                        VerticalBox {
                            padding: 0px;
                            Text {
                                text: "Conveyor";
                                color: #aaaaaa;
                                font-size: 11px;
                            }

                            Text {
                                text: conveyor-status;
                                color: #4fc3f7;
                                font-size: 18px;
                                font-weight: 700;
                            }
                        }
                    }
                }
            }

            // Right Column: Controls. Touch-first: every target >= 48px,
            // the E-stop is by far the largest and always visible.
            Rectangle {
                width: 210px;
                background: #1e1e1e;
                border-radius: 8px;
                VerticalBox {
                    spacing: 8px;
                    padding: 10px;
                    Text {
                        text: "System Controls";
                        color: #ffffff;
                        font-size: 15px;
                        font-weight: 600;
                    }

                    Button {
                        text: command-pending ? "Working…" : (is-running ? "Pause System" : "Start Sorting");
                        primary: true;
                        min-height: 48px;
                        // Locked after E-stop until a successful re-home, and
                        // while a conveyor command is still in flight.
                        enabled: !estopped && !command-pending;
                        clicked => {
                            root.start-clicked();
                        }
                    }

                    Button {
                        text: "Stop Conveyor";
                        min-height: 48px;
                        // Available while running, or after a failed command so
                        // the operator can force the belt down. Never mid-flight.
                        enabled: !command-pending && (is-running || error-text != "");
                        clicked => {
                            root.stop-clicked();
                        }
                    }

                    Button {
                        text: home-pending ? "Homing…" : "Home Robot";
                        min-height: 48px;
                        // Gated on robot business (the confirmed orchestrator
                        // state), never the conveyor: available while paused or
                        // E-stopped — homing is the action that clears the
                        // E-stop interlock — but disabled while actively sorting
                        // (Pause first, so Home can't preempt a live pick) and
                        // while a home is already in progress.
                        enabled: !orchestrator-running && !home-pending;
                        clicked => {
                            root.home-clicked();
                        }
                    }

                    Button {
                        text: gripper-on ? "Release Gripper" : "Engage Gripper";
                        min-height: 48px;
                        // Manual recovery/maintenance action; disabled while
                        // sorting so it can't disturb an active pick sequence.
                        enabled: !is-running;
                        clicked => {
                            root.gripper-toggle(!gripper-on);
                        }
                    }

                    // Workstation-only: save the learned catalogue for copying
                    // to the Pi.
                    if (workstation): Button {
                        text: "Export Catalogue";
                        min-height: 48px;
                        clicked => {
                            root.export-catalog();
                        }
                    }
                    if (workstation && export-status != ""): Text {
                        text: export-status;
                        color: #4fc3f7;
                        font-size: 11px;
                        wrap: word-wrap;
                        horizontal-alignment: center;
                    }

                    if (error-text != ""): Text {
                        text: error-text;
                        color: #f44336;
                        font-size: 11px;
                        wrap: word-wrap;
                        horizontal-alignment: center;
                    }

                    Rectangle { } // Spacer

                    // EMERGENCY STOP: custom drawn (not a std Button) so its
                    // size and colour never depend on the widget theme. The
                    // callback stays synchronous — no new feature may enter
                    // this path.
                    Rectangle {
                        height: 96px;
                        border-radius: 10px;
                        background: estop-touch.pressed ? #8e0000 : #d32f2f;
                        border-width: 3px;
                        border-color: #ff6659;

                        estop-touch := TouchArea {
                            clicked => {
                                root.estop-clicked();
                            }
                        }

                        VerticalBox {
                            padding: 4px;
                            spacing: 0px;
                            Text {
                                text: "EMERGENCY";
                                color: #ffffff;
                                font-size: 22px;
                                font-weight: 900;
                                horizontal-alignment: center;
                                vertical-alignment: bottom;
                            }

                            Text {
                                text: "STOP";
                                color: #ffffff;
                                font-size: 22px;
                                font-weight: 900;
                                horizontal-alignment: center;
                                vertical-alignment: top;
                            }
                        }
                    }
                }
            }
        }
    }

    // Learning overlay (workstation profile only): teach an unrecognised
    // object by assigning it to a known class or creating a new one.
    if (workstation && learning-active): Rectangle {
        width: 100%;
        height: 100%;
        background: #000000dd;

        Rectangle {
            width: 460px;
            height: 420px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: #1e1e1e;
            border-radius: 12px;
            border-width: 1px;
            border-color: #444444;

            VerticalBox {
                padding: 16px;
                spacing: 8px;

                Text {
                    text: "Unknown object — teach it";
                    color: #ffffff;
                    font-size: 18px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }

                Image {
                    source: learn-crop;
                    height: 120px;
                    image-fit: contain;
                }

                Text {
                    text: "Assign to a known class:";
                    color: #aaaaaa;
                    font-size: 12px;
                }

                for candidate in learn-candidates: Button {
                    text: candidate.name + "  (" + candidate.score + ")";
                    clicked => {
                        root.learn-assign(candidate.name);
                    }
                }

                Text {
                    text: "…or create a new class:";
                    color: #aaaaaa;
                    font-size: 12px;
                }

                new-class-name := LineEdit {
                    placeholder-text: "new class name";
                }

                HorizontalBox {
                    padding: 0px;
                    Button {
                        text: "Create";
                        clicked => {
                            root.learn-create(new-class-name.text);
                        }
                    }

                    Button {
                        text: "Skip";
                        clicked => {
                            root.learn-skip();
                        }
                    }
                }
            }
        }
    }
}
