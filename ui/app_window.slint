import {
    Button,
    VerticalBox,
    HorizontalBox,
    StandardListView,
} from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Delta X2 Part Sorting System";
    // Target: the official Raspberry Pi 7" Touch Display. The whole
    // operator view (E-stop included) must fit 800x480 with NO scrolling.
    min-width: 800px;
    min-height: 480px;
    preferred-width: 800px;
    preferred-height: 480px;
    background: #121212;

    in property <image> camera-feed: @image-url("");
    in property <string> robot-status: "Disconnected";
    in property <string> conveyor-status: "Stopped";
    in property <int> bricks-sorted: 0;
    in property <bool> is-running: false;
    // Safety interlock: set from the orchestrator's confirmed state after an
    // E-stop; Start stays disabled until a successful re-home clears it.
    in property <bool> estopped: false;
    // True while a conveyor command is in flight. Debounces the Start/Pause
    // toggle: a double-tap can't spawn a second, racing command.
    in property <bool> command-pending: false;
    // Confirmed orchestrator "actively sorting" state, mirrored from the
    // orchestrator's state watch (robot business, NOT the conveyor). Used to
    // gate Home so it is offered only when homing is meaningful.
    in property <bool> orchestrator-running: false;
    // A Home was requested and has not yet been confirmed complete. Set
    // optimistically on click (like `command-pending` for the belt); cleared
    // when the orchestrator publishes its next confirmed state. Gives the
    // operator immediate feedback and blocks a confusing double-tap.
    in property <bool> home-pending: false;
    // Last hardware error shown to the operator ("" = none). While set, Stop
    // stays available so the belt can be forced down after a failed command.
    in property <string> error-text: "";
    // Manual gripper state (operator toggle). Set optimistically on click;
    // failures surface through error-text.
    in property <bool> gripper-on: false;

    callback start-clicked();
    callback stop-clicked();
    callback home-clicked();
    callback estop-clicked();
    // Operator gripper toggle; argument is the requested new state.
    callback gripper-toggle(bool);

    VerticalBox {
        padding: 10px;
        spacing: 8px;

        // Header (kept shallow so the columns get the vertical space)
        HorizontalBox {
            padding: 0px;
            Text {
                text: "Part Sorting Terminal";
                font-size: 20px;
                color: #ffffff;
                font-weight: 700;
            }

            Rectangle { } // Spacer
            Text {
                text: "Status: " + robot-status;
                color: estopped ? #f44336 : (is-running ? #4caf50 : #ffb74d);
                vertical-alignment: center;
                font-weight: 600;
            }
        }

        HorizontalBox {
            padding: 0px;
            spacing: 10px;

            // Left Column: Live Feed & Analytics
            VerticalBox {
                padding: 0px;
                spacing: 8px;

                // Camera View — flexible: takes whatever height remains.
                Rectangle {
                    background: #1e1e1e;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: #333333;
                    min-height: 160px;
                    vertical-stretch: 1;
                    if (camera-feed.width > 0): Image {
                        source: camera-feed;
                        width: 100%;
                        height: 100%;
                    }
                    if (camera-feed.width == 0): Text {
                        text: "Camera Feed Disconnected";
                        color: #555555;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                    }
                }

                // Stats Box
                Rectangle {
                    background: #1e1e1e;
                    border-radius: 8px;
                    height: 60px;
                    HorizontalBox {
                        padding: 8px;
                        VerticalBox {
                            padding: 0px;
                            Text {
                                text: "Total Sorted";
                                color: #aaaaaa;
                                font-size: 11px;
                            }

                            Text {
                                text: bricks-sorted;
                                color: #ffffff;
                                font-size: 18px;
                                font-weight: 700;
                            }
                        }

                        Rectangle {
                            width: 1px;
                            background: #333333;
                        } // Separator
                        VerticalBox {
                            padding: 0px;
                            Text {
                                text: "Conveyor";
                                color: #aaaaaa;
                                font-size: 11px;
                            }

                            Text {
                                text: conveyor-status;
                                color: #4fc3f7;
                                font-size: 18px;
                                font-weight: 700;
                            }
                        }
                    }
                }
            }

            // Right Column: Controls. Touch-first: every target >= 48px,
            // the E-stop is by far the largest and always visible.
            Rectangle {
                width: 210px;
                background: #1e1e1e;
                border-radius: 8px;
                VerticalBox {
                    spacing: 8px;
                    padding: 10px;
                    Text {
                        text: "System Controls";
                        color: #ffffff;
                        font-size: 15px;
                        font-weight: 600;
                    }

                    Button {
                        text: command-pending ? "Working…" : (is-running ? "Pause System" : "Start Sorting");
                        primary: true;
                        min-height: 48px;
                        // Locked after E-stop until a successful re-home, and
                        // while a conveyor command is still in flight.
                        enabled: !estopped && !command-pending;
                        clicked => {
                            root.start-clicked();
                        }
                    }

                    Button {
                        text: "Stop Conveyor";
                        min-height: 48px;
                        // Available while running, or after a failed command so
                        // the operator can force the belt down. Never mid-flight.
                        enabled: !command-pending && (is-running || error-text != "");
                        clicked => {
                            root.stop-clicked();
                        }
                    }

                    Button {
                        text: home-pending ? "Homing…" : "Home Robot";
                        min-height: 48px;
                        // Gated on robot business (the confirmed orchestrator
                        // state), never the conveyor: available while paused or
                        // E-stopped — homing is the action that clears the
                        // E-stop interlock — but disabled while actively sorting
                        // (Pause first, so Home can't preempt a live pick) and
                        // while a home is already in progress.
                        enabled: !orchestrator-running && !home-pending;
                        clicked => {
                            root.home-clicked();
                        }
                    }

                    Button {
                        text: gripper-on ? "Release Gripper" : "Engage Gripper";
                        min-height: 48px;
                        // Manual recovery/maintenance action; disabled while
                        // sorting so it can't disturb an active pick sequence.
                        enabled: !is-running;
                        clicked => {
                            root.gripper-toggle(!gripper-on);
                        }
                    }

                    if (error-text != ""): Text {
                        text: error-text;
                        color: #f44336;
                        font-size: 11px;
                        wrap: word-wrap;
                        horizontal-alignment: center;
                    }

                    Rectangle { } // Spacer

                    // EMERGENCY STOP: custom drawn (not a std Button) so its
                    // size and colour never depend on the widget theme. The
                    // callback stays synchronous — no new feature may enter
                    // this path.
                    Rectangle {
                        height: 96px;
                        border-radius: 10px;
                        background: estop-touch.pressed ? #8e0000 : #d32f2f;
                        border-width: 3px;
                        border-color: #ff6659;

                        estop-touch := TouchArea {
                            clicked => {
                                root.estop-clicked();
                            }
                        }

                        VerticalBox {
                            padding: 4px;
                            spacing: 0px;
                            Text {
                                text: "EMERGENCY";
                                color: #ffffff;
                                font-size: 22px;
                                font-weight: 900;
                                horizontal-alignment: center;
                                vertical-alignment: bottom;
                            }

                            Text {
                                text: "STOP";
                                color: #ffffff;
                                font-size: 22px;
                                font-weight: 900;
                                horizontal-alignment: center;
                                vertical-alignment: top;
                            }
                        }
                    }
                }
            }
        }
    }
}
